rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: check Firestore isAdmin flag (requires Firestore doc to exist)
    function isFirestoreAdmin() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Helper: check admin by email list (works even without a Firestore user doc)
    function isEmailAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@faarfanna.com' ||
        request.auth.token.email == 'admin@fo.com'
      );
    }

    function isAdmin() {
      return isEmailAdmin() || isFirestoreAdmin();
    }

    // Songs audio files — public read, admin write
    match /songs/audio/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Songs image files — public read, admin write
    match /songs/images/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
